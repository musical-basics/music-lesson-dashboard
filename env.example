# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# LiveKit Configuration
# Get these from your LiveKit Cloud dashboard: https://cloud.livekit.io
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here
NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-server.livekit.cloud

# Cloudflare R2 Recording Storage
R2_ACCOUNT_ID=your_r2_account_id_here
R2_ACCESS_KEY_ID=your_r2_access_key_here
R2_SECRET_ACCESS_KEY=your_r2_secret_key_here
R2_BUCKET_NAME=your_r2_bucket_name_here
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-public-r2-domain.example.com

# Recording Conversion Worker
# Railway start command: pnpm worker:recordings
RAILPACK_DEPLOY_APT_PACKAGES=ffmpeg
RECORDING_CONVERTER_POLL_MS=5000
RECORDING_CONVERTER_MAX_ATTEMPTS=3
RECORDING_CONVERTER_STALE_MINUTES=30
RECORDING_CONVERTER_FFMPEG_PRESET=veryfast
RECORDING_CONVERTER_FFMPEG_CRF=23
RECORDING_CONVERTER_AUDIO_BITRATE=128k

# Optional: notify Piano Studio again when the MP4 is ready.
NOTIFY_PIANO_STUDIO_ON_MP4=false
PIANO_STUDIO_URL=https://your-piano-studio-app.example.com
PIANO_STUDIO_SECRET=your_shared_webhook_secret_here
